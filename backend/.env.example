# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                    YiDao 易道 - 后端环境变量配置                             ║
# ║                                                                           ║
# ║  使用方法:                                                                  ║
# ║  1. 复制此文件为 .env: cp .env.example .env                                ║
# ║  2. 根据你的环境修改下面的配置                                               ║
# ║  3. 带 ⚠️ 标记的是必须修改的敏感配置                                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ============================================================================
# 🚀 应用基础配置
# ============================================================================

# API 路由前缀（所有接口都会以此开头，如 /api/v1/users）
API_PREFIX_V1=/api/v1

# 应用名称（会显示在日志和 API 文档中）
APP_NAME=YiDao

# 运行环境 ▼ 可选值: development / staging / production
# - development: 开发环境，开启调试、详细日志
# - staging: 测试环境，模拟生产但日志详细
# - production: 生产环境，关闭调试、精简日志
APP_ENV=development

# 服务监听地址和端口
APP_HOST=0.0.0.0
APP_PORT=9000

# 调试模式（生产环境务必设为 False）
DEBUG=True

# 时区（影响日志时间戳等）
TIMEZONE=Asia/Shanghai

# ============================================================================
# 🗄️ PostgreSQL 数据库配置
# ============================================================================

# Docker 环境用 "db"，本地开发用 "localhost"
DB_HOST=db
DB_PORT=5432

# ⚠️ 生产环境请修改用户名和密码！
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fastapi-template-db

# 完整数据库 URL（可选，不填则自动根据上面的配置拼接）
# 格式: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=

# 连接池配置（高并发场景可调大）
DB_POOL_SIZE=10           # 连接池大小
DB_MAX_OVERFLOW=20        # 允许超出连接池的临时连接数

# ============================================================================
# 📮 Redis 配置
# ============================================================================

# Docker 环境用 "redis"，本地开发用 "localhost"
# 本机跑后端、用 Docker 只起 redis 时：REDIS_HOST=localhost，REDIS_PORT=6380（compose 映射 6380:6379）
REDIS_HOST=redis
REDIS_PORT=6379

# ⚠️ 生产环境建议设置密码
REDIS_PASSWORD=

# Redis 数据库编号（Redis 有 16 个逻辑数据库: 0-15）
REDIS_DB_CACHE=0          # 业务缓存
REDIS_DB_SESSION=1        # 用户会话
REDIS_DB_CELERY_BROKER=2  # Celery 任务队列
REDIS_DB_CELERY_BACKEND=3 # Celery 结果存储

# ============================================================================
# ⚡ Celery 异步任务配置
# ============================================================================

# Broker URL（任务队列地址，不填则自动使用 Redis 配置）
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# 开发时设为 True 可同步执行任务（方便调试）
CELERY_TASK_ALWAYS_EAGER=False

# 任务超时配置（单位: 秒）
CELERY_TASK_SOFT_TIME_LIMIT=30   # 软超时，发送警告
CELERY_TASK_TIME_LIMIT=60        # 硬超时，强制终止

# ============================================================================
# 🔐 JWT 认证 & 安全配置
# ============================================================================

# ⚠️ 重要！生产环境必须修改为一个随机的长字符串
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# JWT 算法（一般不需要修改）
JWT_ALGORITHM=HS256

# Token 过期时间（单位: 分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30       # Access Token: 30 分钟
REFRESH_TOKEN_EXPIRE_MINUTES=43200   # Refresh Token: 30 天

# 密码加密方式
PASSWORD_HASH_SCHEME=bcrypt

# ============================================================================
# 🌐 CORS 跨域配置
# ============================================================================

# 允许的前端域名列表（JSON 数组格式）
CORS_ALLOW_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 允许的 HTTP 方法
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"]

# 允许的请求头
CORS_ALLOW_HEADERS=["Authorization", "Content-Type"]

# 是否允许携带 Cookie
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# 📝 日志配置
# ============================================================================

# 日志级别 ▼ 可选值: DEBUG / INFO / WARNING / ERROR
# - DEBUG: 最详细，包含所有调试信息
# - INFO: 常规信息
# - WARNING: 只记录警告和错误
# - ERROR: 只记录错误
LOG_LEVEL=INFO

# 是否输出 JSON 格式日志（生产环境推荐 True，方便日志采集）
LOG_JSON=False

# ============================================================================
# 📊 监控 & 指标
# ============================================================================

# 是否启用 Prometheus 指标
ENABLE_METRICS=True

# 指标暴露路径
PROMETHEUS_METRICS_PATH=/metrics

# --- 链路追踪 (OpenTelemetry) ---
# 是否启用分布式链路追踪
ENABLE_TRACING=True

# OTLP 导出器端点 (Jaeger/Tempo)
# Docker 环境环境用 "http://jaeger:4317"，本地开发用 "http://localhost:4317"
OTLP_ENDPOINT=http://localhost:4317

# ============================================================================
# 🚦 限流配置
# ============================================================================

# 是否启用限流
ENABLE_RATE_LIMIT=True

# 默认限流规则（格式: 次数/时间单位，如 200/minute, 1000/hour）
RATE_LIMIT_DEFAULT=200/minute

# ============================================================================
# 🤖 AI / LLM 配置
# ============================================================================

# LLM 提供商 ▼ 可选值: deepseek / openai / qwen
LLM_PROVIDER=deepseek

# ⚠️ DeepSeek API（MVP 默认）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API（备选）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LLM 通用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ============================================================================
# 📡 Langfuse（LLM 可观测性 & Prompt 管理）
# ============================================================================

# 是否启用 Langfuse
LANGFUSE_ENABLED=True

# ⚠️ Langfuse 密钥（自托管或云端均需配置）
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Langfuse 服务地址（自托管用 http://localhost:3100，云端用 https://cloud.langfuse.com）
LANGFUSE_HOST=http://localhost:3100

# ============================================================================
# 📧 第三方服务（按需配置）
# ============================================================================

# SMTP 邮件服务
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
